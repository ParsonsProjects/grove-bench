{
  "name": "grove-bench",
  "version": "0.1.0",
  "description": "Multi-agent git worktree orchestrator for Claude Code",
  "license": "MIT",
  "author": "Alan Parsons",
  "repository": {
    "type": "git",
    "url": "https://github.com/ParsonsProjects/grove-bench.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "start": "node scripts/dev.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.mjs",
    "build:preload": "vite build --config vite.preload.config.mjs",
    "build:renderer": "vite build --config vite.renderer.config.mjs",
    "dist": "npm run build && electron-builder",
    "dist:publish": "npm run build && electron-builder --publish always",
    "postinstall": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "execa": "^9.6.1",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "electron": "~33.3.1",
    "electron-builder": "^26.0.0",
    "jsdom": "^29.0.0",
    "svelte": "^5.20.0",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.0"
  }
}
